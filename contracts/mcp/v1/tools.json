        },
        "additionalProperties": false
      }
    },
    {
      "name": "simulation_resume",
      "description": "Resume toward the existing cumulative target through the browser controller.",
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      },
      "input_schema": {
        "type": "object",
        "required": ["operation_id"],
        "properties": {
          "operation_id": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "simulation_reset",
      "description": "Destroy/reset the bound simulation and restore design editability without changing the design.",
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": true,
        "openWorldHint": false
      },
      "input_schema": {
        "type": "object",
        "required": ["operation_id"],
